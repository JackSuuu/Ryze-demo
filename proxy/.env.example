# ── Backend (Server B via Cloudflare Tunnel B) ────────────────────────────────
BACKEND_URL=https://api.ryze.yourdomain.com

# ── Local listener (cloudflared on Server A connects here) ───────────────────
HOST=127.0.0.1
PORT=8443

# ── Cloudflare Access Service Token ──────────────────────────────────────────
# Get from: Zero Trust → Access → Service Auth → Create Service Token
CF_ACCESS_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx.access
CF_ACCESS_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["https://ryze.yourdomain.com"]

# ── Rate limiting (req/min per IP) ───────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Timeout in seconds (keep long for LLM inference) ─────────────────────────
PROXY_TIMEOUT=300
