# ── BioVLM (wgjazz1 via Cloudflare Tunnel) ───────────────────────────────────
# 本地开发时用 http://127.0.0.1:11436，生产时换成 CF Tunnel 域名
OLLAMA_BASE_URL=https://biolvlm.ryze.yourdomain.com
OLLAMA_MODEL=biovlm-q8_0.gguf

# Cloudflare Access Token — 用于 VPS backend 调用 wgjazz1 BioVLM
# 本地开发留空即可
CF_BIOLVLM_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxx.access
CF_BIOLVLM_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OpenAI / OpenRouter ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1/
OPENAI_MODEL=gpt-4o-mini

# ── Model display name ────────────────────────────────────────────────────────
MODEL_NAME=chivier/BioVLM_8B-V1
