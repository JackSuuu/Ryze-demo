# ============================================================
# BioVLM Comparison Dashboard — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── BioVLM Local Backend (via llama-server / serverless proxy) ──
OLLAMA_BASE_URL=http://127.0.0.1:11436   # serverless proxy port
OLLAMA_MODEL=biovlm-q8_0.gguf           # model name served by llama-server
MODEL_NAME=chivier/BioVLM_8B-V1         # display name

# ── OpenAI-compatible Provider (OpenRouter / OpenAI / etc.) ──
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1/   # or https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
